    "bdd:generation": "npm run build && cucumber-js ../features/exam-pdf-single.feature ../features/exam-pdf-layout.feature ../features/exam-pdf-batch.feature ../features/exam-randomization.feature ../features/exam-answer-key-csv.feature --require ./bdd/step-definitions/**/*.js --require ./bdd/support/**/*.js"
  },
